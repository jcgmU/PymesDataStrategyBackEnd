# =============================================================================
# PYMES Data Strategy - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=pymes
POSTGRES_PASSWORD=pymes_dev_password
POSTGRES_DB=pymes_dev
POSTGRES_PORT=5433

# Connection string for Prisma (computed from above)
DATABASE_URL=postgresql://pymes:pymes_dev_password@localhost:5433/pymes_dev

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380

# -----------------------------------------------------------------------------
# MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false

# Bucket names
MINIO_BUCKET_DATASETS=datasets
MINIO_BUCKET_RESULTS=results
MINIO_BUCKET_TEMP=temp

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------
API_PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Worker ETL
# -----------------------------------------------------------------------------
WORKER_PORT=8000
WORKER_CONCURRENCY=2
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# ==========================================================================
# AUTH
# ==========================================================================
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# n8n Integration (AI Suggestions via Gemini)
# -----------------------------------------------------------------------------
# Webhook URL from n8n workflow "AI Suggestions Generator"
N8N_SUGGESTIONS_WEBHOOK_URL=https://jcgm1047.app.n8n.cloud/webhook/ai-suggestions
# Shared secret between backend and n8n (use a strong random value in production)
N8N_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# -----------------------------------------------------------------------------
# Gemini API (NL Edit — InstructionParser)
# -----------------------------------------------------------------------------
# API key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model to use (default if not set: gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp
# Kill switch: set to "false" to disable NL parsing (fallback to literal-only mode)
INSTRUCTION_PARSER_ENABLED=true
