# =============================================================================
# PYMES Data Strategy - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=pymes
POSTGRES_PASSWORD=pymes_dev_password
POSTGRES_DB=pymes_dev
POSTGRES_PORT=5433

# Connection string for Prisma (computed from above)
DATABASE_URL=postgresql://pymes:pymes_dev_password@localhost:5433/pymes_dev

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380

# -----------------------------------------------------------------------------
# MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false

# Bucket names
MINIO_BUCKET_DATASETS=datasets
MINIO_BUCKET_RESULTS=results
MINIO_BUCKET_TEMP=temp

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------
API_PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Worker ETL
# -----------------------------------------------------------------------------
WORKER_PORT=8000
WORKER_CONCURRENCY=2
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# ==========================================================================
# AUTH
# ==========================================================================
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# n8n Integration (AI Suggestions — opcional, fallback si no hay GEMINI_API_KEY)
# -----------------------------------------------------------------------------
# URL del webhook en tu instancia de n8n (dejar vacío para deshabilitar)
N8N_SUGGESTIONS_WEBHOOK_URL=
# Secreto compartido entre el backend y n8n
N8N_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# -----------------------------------------------------------------------------
# Gemini API (NL Edit — InstructionParser + sugerencias AI del Worker)
# -----------------------------------------------------------------------------
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# Sin esta clave el NL Edit solo acepta instrucciones literales (números, null, texto entre comillas)
GEMINI_API_KEY=
# Modelo a usar — recomendado: gemini-2.5-flash (gemini-2.0-flash ya no está disponible para cuentas nuevas)
GEMINI_MODEL=gemini-2.5-flash
# Kill switch: "false" deshabilita el parsing NL (modo literal únicamente)
INSTRUCTION_PARSER_ENABLED=true
